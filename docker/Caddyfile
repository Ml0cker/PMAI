{$DOMAIN:pmai.fun} {
	# API proxy (strip /api prefix)
	handle_path /api/* {
		reverse_proxy api:4000
	}

	# WebSocket proxy
	handle /ws {
		reverse_proxy api:4000 {
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}

	# Frontend (everything else)
	handle {
		reverse_proxy frontend:3000
	}
}
